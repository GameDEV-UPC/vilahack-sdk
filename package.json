{
  "name": "@gamedev.upc/vilahack-sdk",
  "version": "0.2.1",
  "description": "The official TypeScript SDK for Vilahack",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./team": {
      "types": "./dist/team/index.d.ts",
      "import": "./dist/team/index.js",
      "default": "./dist/team/index.js"
    },
    "./user": {
      "types": "./dist/user/index.d.ts",
      "import": "./dist/user/index.js",
      "default": "./dist/user/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build"
  },
  "files": [
    "dist"
  ],
  "author": "Joel Esteller Planesas",
  "license": "MIT",
  "homepage": "https://github.com/GameDEV-UPC/vilahack-sdk",
  "devDependencies": {
    "@supabase/supabase-js": "^2.103.0",
    "@types/inquirer": "^9.0.9",
    "@types/node": "^25.6.0",
    "dotenv": "^17.4.1",
    "inquirer": "^13.4.1",
    "prettier": "^3.8.2",
    "typescript": "^6.0.2",
    "@gamedev.upc/vilahack-sdk": "^0.2.1"
  }
}
